# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/learn_english
DB_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@learnenglish.app

# Minimax API (旧版 abab 模型)
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=your-minimax-group-id

# MiniMax M2.5 API (Anthropic 兼容)
# 从 https://platform.minimaxi.com/subscribe/token-plan 获取
MINIMAX_M2_API_KEY=your-minimax-m2-api-key
APP_URL=http://your-domain-or-ip:port

# Observability
SLOW_REQUEST_MS=1000
SLOW_QUERY_MS=200
ERROR_ALERT_WEBHOOK_URL=
ERROR_ALERT_COOLDOWN_MS=60000
